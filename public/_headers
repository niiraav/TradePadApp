# Cloudflare Pages — Cache headers for PWA
# Service worker and manifest must never be cached by the browser
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.json
  Cache-Control: no-cache, no-store, must-revalidate

/registerSW.js
  Cache-Control: no-cache, no-store, must-revalidate

# Long-term cache for hashed assets (Vite build output)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# icons are versioned via query params or filename changes
/icons/*
  Cache-Control: public, max-age=31536000, immutable
